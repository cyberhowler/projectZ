# ProjectZ v1.0 — Environment Configuration
# Copy: cp .env.example .env
# Then fill in your free API keys (all optional — tool works without them)

# ─────────────────────────────────────────────────────────────────────────────
# THREAT INTELLIGENCE
# ─────────────────────────────────────────────────────────────────────────────
# VirusTotal  — 500 req/day free  — https://virustotal.com
VIRUSTOTAL_API_KEY=

# AlienVault OTX — unlimited free — https://otx.alienvault.com
OTX_API_KEY=

# AbuseIPDB  — 1000 req/day free — https://www.abuseipdb.com/register
ABUSEIPDB_API_KEY=

# URLScan.io — 5000 req/month free — https://urlscan.io
URLSCAN_API_KEY=

# PhishTank  — free with account — https://www.phishtank.com/api_info.php
PHISHTANK_API_KEY=

# Google Safe Browsing — 10k req/day free — https://developers.google.com/safe-browsing
GOOGLE_SAFE_BROWSING_KEY=

# Intelligence X — limited free — https://intelx.io
INTELX_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# BREACH & DATA EXPOSURE
# ─────────────────────────────────────────────────────────────────────────────
# HaveIBeenPwned — paid for per-email, free for domain — https://haveibeenpwned.com/API/Key
HIBP_API_KEY=

# CertSpotter — 100 req/hour free — https://sslmate.com/certspotter/api
CERTSPOTTER_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# RECON & INFRASTRUCTURE
# ─────────────────────────────────────────────────────────────────────────────
# Shodan — limited free (1 result) — https://account.shodan.io/register
SHODAN_API_KEY=

# Censys — 250 queries/month free — https://censys.io/register
CENSYS_API_ID=
CENSYS_API_SECRET=

# GitHub — 5000 req/hr free — https://github.com/settings/tokens
GITHUB_TOKEN=

# ZoomEye — 10k results/month free — https://www.zoomeye.org
ZOOMEYE_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# NOTIFICATIONS (optional — webhook alerts on critical findings)
# ─────────────────────────────────────────────────────────────────────────────
# Slack webhook — https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK=

# Discord webhook — Server Settings > Integrations > Webhooks
DISCORD_WEBHOOK=

# Minimum severity to trigger notification: critical | high | medium
NOTIFY_SEVERITY=critical

# ─────────────────────────────────────────────────────────────────────────────
# ENGINE SETTINGS
# ─────────────────────────────────────────────────────────────────────────────
# HTTP timeout per request (seconds)
REQUEST_TIMEOUT=15

# Max simultaneous module workers
MAX_CONCURRENT=20

# Cache time-to-live (hours) — set 0 to disable cache
CACHE_TTL_HOURS=24

# Output directory for scan results
OUTPUT_DIR=data/results

# SQLite database path
DB_PATH=data/db/projectz.db

# Proxy (optional) — format: http://user:pass@host:port
# HTTP_PROXY=
# HTTPS_PROXY=

# Custom User-Agent (leave blank for rotating UA)
USER_AGENT=
